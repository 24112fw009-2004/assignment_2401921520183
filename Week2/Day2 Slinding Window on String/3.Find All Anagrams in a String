#include <iostream>
#include <vector>
#include <string>
using namespace std;

class Solution {
public:
    vector<int> findAnagrams(string s, string p) {
        vector<int> result;

        if (p.size() > s.size())
            return result;

        vector<int> pCount(26, 0);
        vector<int> windowCount(26, 0);

        for (char c : p)
            pCount[c - 'a']++;

        int k = p.size();

        for (int i = 0; i < k; i++)
            windowCount[s[i] - 'a']++;

        if (windowCount == pCount)
            result.push_back(0);

        for (int i = k; i < s.size(); i++) {
            windowCount[s[i] - 'a']++;
            windowCount[s[i - k] - 'a']--;

            if (windowCount == pCount)
                result.push_back(i - k + 1);
        }

        return result;
    }
};

int main() {
    Solution sol;

    string s, p;

    cout << "Enter string s: ";
    cin >> s;

    cout << "Enter pattern p: ";
    cin >> p;

    vector<int> ans = sol.findAnagrams(s, p);

    cout << "Anagram starting indices: ";
    for (int idx : ans)
        cout << idx << " ";

    cout << endl;

    return 0;
}